FoamFile
{
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [ 0 1 -1 0 0 0 0 ];

internalField   uniform ( 0 0 0 );

boundaryField
{
    maxY
    {
        type            pressureInletOutletVelocity;
        value           uniform ( 0 0 0 );
    }

    minX            { type noSlip; }
    maxX            { type noSlip; }
    minY            { type noSlip; }
    fluid_to_solid1 { type noSlip; }
    fluid_to_solid2 { type noSlip; }
    empty           { type  empty; }

    #includeEtc "caseDicts/setConstraintTypes"
}


