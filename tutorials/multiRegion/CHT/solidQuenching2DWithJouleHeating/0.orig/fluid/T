FoamFile
{
    format      ascii;
    class       volScalarField;
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [ 0 0 0 1 0 0 0 ];

internalField   uniform 300;

boundaryField
{
    maxY
    {
        type            inletOutlet;
        value           uniform 300;
        inletValue      uniform 300;
    }

    minX
    {
        type            fixedValue;
        value           uniform 300;
    }
    maxX
    {
        type            fixedValue;
        value           uniform 300;
    }

    minY
    {
        type            fixedValue;
        value           uniform 300;
    }

    fluid_to_solid1
    {
        type            coupledTemperature;
        value           $internalField;
    }
    fluid_to_solid2
    {
        type            coupledTemperature;
        value           $internalField;
    }

    ".*"
    {
        type            zeroGradient;
    }

    #includeEtc "caseDicts/setConstraintTypes"
}


